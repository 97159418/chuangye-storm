<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>创野风暴 | CYSTORM — 定制开发与 AI Agent</title>
<meta name="description" content="创野风暴，专注定制开发与 AI Agent 解决方案。用技术驱动未来。">
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚡</text></svg>">
<style>
/* ===== Reset & Base ===== */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --bg: #050510;
  --bg2: #0a0a1a;
  --bg3: #0f0f2a;
  --text: #e8e8f0;
  --text-dim: #7a7a9a;
  --accent: #3d7eff;
  --accent2: #7c3aed;
  --glow: rgba(61, 126, 255, 0.15);
  --radius: 16px;
  --transition: 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

html { scroll-behavior: smooth; }

body {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI',
    'PingFang SC', 'Microsoft YaHei', sans-serif;
  background: var(--bg); color: var(--text);
  overflow-x: hidden; line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

a { color: inherit; text-decoration: none; }

/* ===== Utilities ===== */
.container { max-width: 1200px; margin: 0 auto; padding: 0 40px; }

/* ===== Navigation ===== */
.nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 0 48px; height: 64px;
  display: flex; align-items: center; justify-content: space-between;
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  background: rgba(5, 5, 16, 0.85);
  border-bottom: 1px solid rgba(255,255,255,0.04);
  transition: background 0.3s;
}
.nav.scrolled { background: rgba(5, 5, 16, 0.95); }

.nav-logo {
  font-size: 18px; font-weight: 700; letter-spacing: 2px;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}
.nav-logo span { font-weight: 400; opacity: 0.6; -webkit-text-fill-color: var(--text-dim); font-size: 13px; margin-left: 8px; letter-spacing: 1px; }

.nav-links { display: flex; gap: 36px; align-items: center; }
.nav-links a {
  font-size: 14px; color: var(--text-dim); letter-spacing: 0.5px;
  transition: color 0.3s; position: relative;
}
.nav-links a:hover { color: var(--text); }
.nav-links a::after {
  content: ''; position: absolute; bottom: -4px; left: 0;
  width: 0; height: 1.5px; background: var(--accent);
  transition: width 0.3s;
}
.nav-links a:hover::after { width: 100%; }

.nav-cta {
  padding: 8px 20px; border-radius: 100px; font-size: 13px;
  background: var(--accent); color: #fff; font-weight: 500;
  transition: all 0.3s; border: none; cursor: pointer;
}
.nav-cta:hover { background: #5a93ff; transform: translateY(-1px); box-shadow: 0 4px 20px var(--glow); }

/* 汉堡菜单按钮 */
.nav-hamburger {
  display: none; background: none; border: none; cursor: pointer;
  width: 32px; height: 32px; position: relative; flex-shrink: 0;
}
.nav-hamburger span,
.nav-hamburger span::before,
.nav-hamburger span::after {
  display: block; width: 20px; height: 2px; background: var(--text-dim);
  border-radius: 2px; transition: all 0.3s; position: absolute; left: 6px;
}
.nav-hamburger span { top: 15px; }
.nav-hamburger span::before { content: ''; top: -6px; }
.nav-hamburger span::after { content: ''; top: 6px; }
.nav-hamburger.active span { background: transparent; }
.nav-hamburger.active span::before { top: 0; transform: rotate(45deg); }
.nav-hamburger.active span::after { top: 0; transform: rotate(-45deg); }

/* 移动端菜单 */
.mobile-menu {
  display: none; position: fixed; top: 64px; left: 0; right: 0; bottom: 0;
  background: rgba(5, 5, 16, 0.97); backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px); z-index: 99;
  flex-direction: column; align-items: center; justify-content: center; gap: 32px;
  opacity: 0; transition: opacity 0.3s;
}
.mobile-menu.open { opacity: 1; pointer-events: auto; }
.mobile-menu a {
  font-size: 20px; color: var(--text-dim); transition: color 0.3s;
}
.mobile-menu a:hover { color: var(--text); }

/* ===== Hero ===== */
.hero {
  min-height: 100vh; display: flex; flex-direction: column;
  justify-content: center; align-items: center; text-align: center;
  position: relative; overflow: hidden; padding: 120px 40px 80px;
}

/* 背景粒子/网格 */
.hero::before {
  content: ''; position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 80% 50% at 50% 0%, rgba(61,126,255,0.08) 0%, transparent 60%),
    radial-gradient(ellipse 60% 40% at 70% 80%, rgba(124,58,237,0.06) 0%, transparent 50%);
  pointer-events: none;
}

/* 动态光球 */
.hero-orb {
  position: absolute; border-radius: 50%; filter: blur(80px);
  opacity: 0.3; animation: orbFloat 8s ease-in-out infinite alternate;
  pointer-events: none; will-change: transform;
}
.hero-orb.orb1 {
  width: 500px; height: 500px;
  background: radial-gradient(circle, var(--accent), transparent);
  top: -100px; right: -100px;
}
.hero-orb.orb2 {
  width: 400px; height: 400px;
  background: radial-gradient(circle, var(--accent2), transparent);
  bottom: -80px; left: -80px;
  animation-delay: -4s; animation-direction: alternate-reverse;
}

@keyframes orbFloat {
  0% { transform: translate(0, 0) scale(1); }
  100% { transform: translate(30px, -40px) scale(1.1); }
}

.hero-badge {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 6px 18px; border-radius: 100px; font-size: 13px;
  background: rgba(61, 126, 255, 0.08); border: 1px solid rgba(61, 126, 255, 0.15);
  color: var(--accent); margin-bottom: 32px; letter-spacing: 1px;
  animation: fadeUp 0.8s ease both;
}
.hero-badge::before {
  content: ''; width: 6px; height: 6px; border-radius: 50%;
  background: var(--accent); animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.8); }
}

.hero h1 {
  font-size: clamp(48px, 8vw, 96px); font-weight: 800;
  line-height: 1.05; letter-spacing: -2px;
  margin-bottom: 28px; animation: fadeUp 0.8s 0.15s ease both;
}

.hero h1 .gradient {
  background: linear-gradient(135deg, #fff 30%, var(--accent) 60%, var(--accent2));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero p {
  font-size: clamp(16px, 2vw, 20px); color: var(--text-dim);
  max-width: 580px; line-height: 1.7;
  animation: fadeUp 0.8s 0.3s ease both;
}

.hero-actions {
  display: flex; gap: 16px; margin-top: 48px;
  animation: fadeUp 0.8s 0.45s ease both;
}

.btn-primary {
  padding: 14px 36px; border-radius: 100px; font-size: 15px;
  background: var(--accent); color: #fff; font-weight: 600;
  transition: all 0.3s; border: none; cursor: pointer;
  display: inline-flex; align-items: center; gap: 8px;
}
.btn-primary:hover {
  background: #5a93ff; transform: translateY(-2px);
  box-shadow: 0 8px 32px var(--glow);
}

.btn-outline {
  padding: 14px 36px; border-radius: 100px; font-size: 15px;
  background: transparent; color: var(--text); font-weight: 500;
  border: 1px solid rgba(255,255,255,0.12); cursor: pointer;
  transition: all 0.3s;
}
.btn-outline:hover {
  border-color: rgba(255,255,255,0.3);
  background: rgba(255,255,255,0.04);
  transform: translateY(-2px);
}

.hero-scroll {
  position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  color: var(--text-dim); font-size: 12px; letter-spacing: 2px;
  animation: fadeUp 0.8s 0.6s ease both;
}
.hero-scroll .line {
  width: 1px; height: 40px; background: linear-gradient(to bottom, var(--accent), transparent);
  animation: scrollLine 2s infinite;
}
@keyframes scrollLine {
  0% { transform: scaleY(0); transform-origin: top; }
  50% { transform: scaleY(1); transform-origin: top; }
  51% { transform: scaleY(1); transform-origin: bottom; }
  100% { transform: scaleY(0); transform-origin: bottom; }
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ===== Section: Services ===== */
.section { padding: 140px 0; }

.section-label {
  font-size: 13px; color: var(--accent); letter-spacing: 3px;
  text-transform: uppercase; margin-bottom: 16px; font-weight: 600;
}

.section-title {
  font-size: clamp(32px, 4vw, 52px); font-weight: 700;
  line-height: 1.15; letter-spacing: -1px; margin-bottom: 20px;
}

.section-desc {
  font-size: 17px; color: var(--text-dim); max-width: 560px;
  line-height: 1.7; margin-bottom: 64px;
}

.services-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
  gap: 24px;
}

.service-card {
  background: linear-gradient(135deg, var(--bg2), var(--bg3));
  border: 1px solid rgba(255,255,255,0.05);
  border-radius: var(--radius); padding: 48px 40px;
  transition: all var(--transition); position: relative; overflow: hidden;
}
.service-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0;
  height: 2px; background: linear-gradient(90deg, var(--accent), var(--accent2));
  transform: scaleX(0); transform-origin: left; transition: transform 0.5s;
}
.service-card:hover { transform: translateY(-4px); border-color: rgba(61,126,255,0.15); }
.service-card:hover::before { transform: scaleX(1); }

.service-icon {
  width: 56px; height: 56px; border-radius: 14px;
  background: linear-gradient(135deg, rgba(61,126,255,0.12), rgba(124,58,237,0.12));
  display: flex; align-items: center; justify-content: center;
  font-size: 26px; margin-bottom: 28px;
}

.service-card h3 {
  font-size: 22px; font-weight: 600; margin-bottom: 14px;
}
.service-card p {
  font-size: 15px; color: var(--text-dim); line-height: 1.7;
}

.service-tags {
  display: flex; flex-wrap: wrap; gap: 8px; margin-top: 24px;
}
.service-tags span {
  padding: 4px 14px; border-radius: 100px; font-size: 12px;
  background: rgba(61,126,255,0.06); border: 1px solid rgba(61,126,255,0.1);
  color: var(--accent);
}

/* ===== Section: Philosophy ===== */
.philosophy {
  display: grid; grid-template-columns: 1fr 1fr; gap: 80px;
  align-items: center;
}

.philosophy-visual {
  position: relative; height: 480px; border-radius: var(--radius);
  background: linear-gradient(135deg, var(--bg2), var(--bg3));
  border: 1px solid rgba(255,255,255,0.04);
  overflow: hidden; display: flex; align-items: center; justify-content: center;
}

/* 代码风格动画 */
.code-block {
  font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
  font-size: 14px; line-height: 1.8; padding: 40px;
  color: var(--text-dim); width: 100%;
}
.code-block .line { opacity: 0; animation: codeFade 0.5s ease forwards; }
@keyframes codeFade {
  from { opacity: 0; transform: translateX(-10px); }
  to { opacity: 1; transform: translateX(0); }
}
.code-block .kw { color: var(--accent2); }
.code-block .fn { color: var(--accent); }
.code-block .str { color: #4ade80; }
.code-block .cm { color: #555580; }
.code-block .num { color: #f59e0b; }

.philosophy h2 {
  font-size: clamp(28px, 3.5vw, 44px); font-weight: 700;
  line-height: 1.2; letter-spacing: -1px; margin-bottom: 24px;
}
.philosophy p {
  font-size: 16px; color: var(--text-dim); line-height: 1.8; margin-bottom: 16px;
}

.stats {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px;
  margin-top: 48px;
}
.stat-num {
  font-size: 36px; font-weight: 700;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}
.stat-label { font-size: 13px; color: var(--text-dim); margin-top: 4px; }

/* ===== Section: Tech Stack ===== */
.tech-track-wrapper {
  overflow: hidden;
  mask-image: linear-gradient(90deg, transparent, black 10%, black 90%, transparent);
  -webkit-mask-image: linear-gradient(90deg, transparent, black 10%, black 90%, transparent);
  padding: 20px 0;
}
.tech-track {
  display: flex; gap: 16px; width: max-content;
  animation: scrollTrack var(--scroll-duration, 30s) linear infinite;
}
.tech-pill {
  padding: 10px 24px; border-radius: 100px; font-size: 14px; white-space: nowrap;
  background: var(--bg2); border: 1px solid rgba(255,255,255,0.06);
  color: var(--text-dim); transition: all 0.3s; flex-shrink: 0;
}
.tech-pill:hover { border-color: rgba(61,126,255,0.2); color: var(--text); }

@keyframes scrollTrack {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ===== Section: CTA ===== */
.cta-section {
  text-align: center; padding: 160px 40px;
  position: relative;
}
.cta-section::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse 70% 50% at 50% 50%, rgba(61,126,255,0.06), transparent);
  pointer-events: none;
}
.cta-section h2 {
  font-size: clamp(36px, 5vw, 64px); font-weight: 700;
  letter-spacing: -1px; margin-bottom: 20px;
}
.cta-section p {
  font-size: 18px; color: var(--text-dim); margin-bottom: 48px;
  max-width: 500px; margin-left: auto; margin-right: auto;
}

/* ===== Footer ===== */
.footer {
  border-top: 1px solid rgba(255,255,255,0.04);
  padding: 48px 0; font-size: 13px; color: var(--text-dim);
}
.footer-inner {
  display: flex; justify-content: space-between; align-items: center;
}
.footer-links { display: flex; gap: 28px; }
.footer-links a { transition: color 0.3s; }
.footer-links a:hover { color: var(--text); }

/* ===== Scroll Reveal ===== */
.reveal {
  opacity: 0; transform: translateY(40px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}
.reveal.visible { opacity: 1; transform: translateY(0); }

/* ===== Responsive ===== */
@media (max-width: 768px) {
  .nav { padding: 0 20px; }
  .nav-links, .nav-cta { display: none; }
  .nav-hamburger { display: block; }
  .mobile-menu { display: flex; }
  .container { padding: 0 24px; }
  .hero { padding: 100px 24px 60px; }
  .hero-actions { flex-direction: column; align-items: center; }
  .hero-orb { filter: blur(50px); opacity: 0.15; }
  .section { padding: 80px 0; }
  .philosophy { grid-template-columns: 1fr; gap: 40px; }
  .philosophy-visual { height: 320px; }
  .stats { grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .stat-num { font-size: 28px; }
  .footer-inner { flex-direction: column; gap: 16px; text-align: center; }
  .services-grid { grid-template-columns: 1fr; }
  .service-card { padding: 32px 24px; }
  .cta-section { padding: 100px 24px; }
}
</style>
</head>
<body>

<!-- Navigation -->
<nav class="nav" id="nav">
  <a href="#" class="nav-logo">创野风暴<span>CYSTORM</span></a>
  <div class="nav-links">
    <a href="#services">服务</a>
    <a href="#about">理念</a>
    <a href="#tech">技术</a>
    <a href="#contact">联系</a>
  </div>
  <button class="nav-cta" id="navCta">开始合作</button>
  <button class="nav-hamburger" id="navHamburger" aria-label="菜单">
    <span></span>
  </button>
</nav>

<!-- 移动端菜单 -->
<div class="mobile-menu" id="mobileMenu">
  <a href="#services">服务</a>
  <a href="#about">理念</a>
  <a href="#tech">技术</a>
  <a href="#contact">联系</a>
</div>

<!-- Hero -->
<section class="hero">
  <div class="hero-orb orb1"></div>
  <div class="hero-orb orb2"></div>

  <div class="hero-badge">
    <span></span>AI Agent · 定制开发
  </div>

  <h1>
    <span class="gradient">用技术</span><br>
    <span class="gradient">驱动你的未来</span>
  </h1>

  <p>我们为企业打造定制化软件解决方案与智能 AI Agent，<br>让每一家公司都拥有属于自己的技术竞争力。</p>

  <div class="hero-actions">
    <a href="#contact" class="btn-primary">开启项目 →</a>
    <a href="#services" class="btn-outline">了解服务</a>
  </div>

  <div class="hero-scroll">
    <span>SCROLL</span>
    <div class="line"></div>
  </div>
</section>

<!-- Services -->
<section class="section" id="services">
  <div class="container">
    <div class="reveal">
      <div class="section-label">SERVICES</div>
      <div class="section-title">两大核心能力，<br>驱动业务增长</div>
      <div class="section-desc">从底层架构到智能应用，我们提供全链路的技术解决方案，让想法变成现实。</div>
    </div>

    <div class="services-grid">
      <div class="service-card reveal">
        <div class="service-icon">⚡</div>
        <h3>定制软件开发</h3>
        <p>深度理解业务逻辑，从零构建专属系统。无论是企业内部管理平台、数据中台，还是面向用户的移动端应用，我们都能精准交付。</p>
        <div class="service-tags">
          <span>Web 应用</span>
          <span>移动端</span>
          <span>数据平台</span>
          <span>微服务架构</span>
        </div>
      </div>

      <div class="service-card reveal">
        <div class="service-icon">🧠</div>
        <h3>AI Agent 解决方案</h3>
        <p>不只是接入大模型，而是打造真正能理解你业务的 AI 助手。从智能客服到自动化工作流，让 AI 成为你团队的超级成员。</p>
        <div class="service-tags">
          <span>智能客服</span>
          <span>工作流自动化</span>
          <span>RAG 知识库</span>
          <span>多模态交互</span>
        </div>
      </div>

      <div class="service-card reveal">
        <div class="service-icon">🔗</div>
        <h3>系统集成与升级</h3>
        <p>打通信息孤岛，让旧系统焕发新生。API 对接、数据库迁移、性能优化，我们帮你平滑过渡到下一代架构。</p>
        <div class="service-tags">
          <span>API 集成</span>
          <span>数据库迁移</span>
          <span>性能优化</span>
          <span>云原生改造</span>
        </div>
      </div>

      <div class="service-card reveal">
        <div class="service-icon">🛡️</div>
        <h3>技术咨询与架构设计</h3>
        <p>不确定从哪里开始？我们提供技术诊断、架构评审和路线规划，帮你在投入之前就看清方向。</p>
        <div class="service-tags">
          <span>技术诊断</span>
          <span>架构评审</span>
          <span>选型建议</span>
          <span>团队赋能</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Philosophy / About -->
<section class="section" id="about">
  <div class="container">
    <div class="philosophy">
      <div class="philosophy-visual reveal" id="codeVisual">
        <div class="code-block" id="codeBlock"></div>
      </div>

      <div class="reveal">
        <div class="section-label">PHILOSOPHY</div>
        <div class="section-title">不只是写代码，<br>是构建价值</div>
        <p>我们相信好的技术应该「消失」——用户感知不到它的存在，却能享受到它带来的流畅体验。</p>
        <p>每一个项目，我们都以架构师的视角思考全局，以工匠的精神打磨细节。不堆功能，不凑活，只为交付让客户真正满意的产品。</p>

        <div class="stats">
          <div>
            <div class="stat-num">50+</div>
            <div class="stat-label">项目交付</div>
          </div>
          <div>
            <div class="stat-num">98%</div>
            <div class="stat-label">客户续约率</div>
          </div>
          <div>
            <div class="stat-num">7×24</div>
            <div class="stat-label">技术支持</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Tech Stack -->
<section class="section" id="tech">
  <div class="container">
    <div class="reveal" style="text-align: center; margin-bottom: 60px;">
      <div class="section-label">TECH STACK</div>
      <div class="section-title">技术选型，只为最优解</div>
    </div>
  </div>

  <div class="tech-track-wrapper">
    <div class="tech-track" id="techTrack">
      <!-- JS 会自动填充并克隆 -->
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section" id="contact">
  <div class="reveal">
    <h2>准备好<br>开启下一个项目了吗？</h2>
    <p>无论是一个想法还是一份详细的需求文档，我们都期待与你聊聊。</p>
    <a href="mailto:hello@cystorm.com" class="btn-primary">联系我们 →</a>
  </div>
</section>

<!-- Footer -->
<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <div>© 2026 创野风暴 CYSTORM. All rights reserved.</div>
      <div class="footer-links">
        <a href="mailto:hello@cystorm.com">hello@cystorm.com</a>
      </div>
    </div>
  </div>
</footer>

<!-- Scripts -->
<script>
// 导航栏滚动效果
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => {
  nav.classList.toggle('scrolled', window.scrollY > 50);
});

// 汉堡菜单
const hamburger = document.getElementById('navHamburger');
const mobileMenu = document.getElementById('mobileMenu');
hamburger.addEventListener('click', () => {
  hamburger.classList.toggle('active');
  mobileMenu.classList.toggle('open');
  document.body.style.overflow = mobileMenu.classList.contains('open') ? 'hidden' : '';
});
// 点击菜单项后关闭
mobileMenu.querySelectorAll('a').forEach(a => {
  a.addEventListener('click', () => {
    hamburger.classList.remove('active');
    mobileMenu.classList.remove('open');
    document.body.style.overflow = '';
  });
});

// 统一的平滑滚动（导航按钮）
function smoothScrollTo(id) {
  const el = document.getElementById(id);
  if (el) el.scrollIntoView({ behavior: 'smooth' });
}
document.getElementById('navCta').addEventListener('click', () => smoothScrollTo('contact'));

// 滚动显示动画
const reveals = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

reveals.forEach(el => observer.observe(el));

// Code block 动态生成 + 动画
const codeLines = [
  ['cm', '// 创野风暴的做事方式'],
  ['kw', 'const ', 'fn', 'build ', '', '= ', 'kw', 'async ', '', '(idea) => {'],
  ['', '  ', 'kw', 'const ', '', 'plan = ', 'kw', 'await ', 'fn', 'understand', '', '(idea);'],
  ['', '  ', 'kw', 'const ', '', 'code = ', 'fn', 'craft', '', '(plan, {'],
  ['', '    quality: ', 'str', '"极致",', ''],
  ['', '    speed: ', 'num', '99,', ''],
  ['', '  });'],
  ['', '  ', 'kw', 'return ', 'fn', 'ship', '', '(code);'],
  ['', '};'],
];

const codeBlock = document.getElementById('codeBlock');
codeLines.forEach((tokens, i) => {
  const line = document.createElement('div');
  line.className = 'line';
  line.style.animationDelay = `${0.5 + i * 0.3}s`;
  let html = '';
  for (let j = 0; j < tokens.length; j += 2) {
    const cls = tokens[j];
    const text = tokens[j + 1];
    if (cls) {
      html += `<span class="${cls}">${text}</span>`;
    } else {
      html += text;
    }
  }
  line.innerHTML = html;
  codeBlock.appendChild(line);
});

// Tech Stack 滚动（JS 动态计算确保无缝）
const techs = [
  'Python', 'TypeScript', 'Go', 'Rust', 'React', 'Next.js', 'Vue.js',
  'Node.js', 'LangChain', 'OpenAI', 'Claude API', 'PostgreSQL',
  'Redis', 'Docker', 'Kubernetes', 'AWS', 'Cloudflare'
];

const techTrack = document.getElementById('techTrack');
function buildTechTrack() {
  techTrack.innerHTML = '';
  // 生成两份副本用于无缝滚动
  for (let copy = 0; copy < 2; copy++) {
    techs.forEach(name => {
      const pill = document.createElement('div');
      pill.className = 'tech-pill';
      pill.textContent = name;
      techTrack.appendChild(pill);
    });
  }
  // 根据实际宽度计算动画时长，确保匀速滚动
  const singleWidth = techTrack.scrollWidth / 2;
  const speed = 60; // px/s
  const duration = singleWidth / speed;
  techTrack.style.setProperty('--scroll-duration', duration + 's');
}
buildTechTrack();
</script>

</body>
</html>
